<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Portfolio</title>
    
    <style>
        /* --- CSS: ここに見た目の設定を書きます --- */

        /* 1. 全体の設定 */
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            font-family: "Helvetica Neue", Arial, sans-serif;
            overflow-x: hidden; /* 横揺れ防止 */
        }

        /* 2. 背景動画の設定 */
        #video-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover; /* 画面いっぱいに広げる */
            z-index: -1; /* コンテンツの背後に配置 */
        }

        /* 3. ヘッダー（メニュー）の設定 */
        header {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 30px 50px;
            box-sizing: border-box;
            z-index: 100;
        }

        nav ul {
            list-style: none;
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: flex-end; /* 右寄せ */
            gap: 30px; /* メニュー間の余白 */
        }

        nav ul li a {
            text-decoration: none;
            color: white;
            font-weight: bold;
            font-size: 14px;
            letter-spacing: 0.1em;
            transition: 0.3s;
            text-shadow: 1px 1px 5px rgba(0,0,0,0.3); /* 文字を読みやすく */
        }

        nav ul li a:hover {
            color: #ccc; /* マウスを乗せた時の色 */
        }

        /* 4. 真ん中のメインテキスト */
        .main-content {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            color: white;
            text-align: center;
        }

        .main-content h1 {
            font-size: 4rem;
            margin: 0;
            text-shadow: 0 0 20px rgba(0,0,0,0.5);
        }

        /* スマホ用の調整 */
        @media (max-width: 768px) {
            header {
                padding: 20px;
            }
            nav ul {
                gap: 15px;
            }
            nav ul li a {
                font-size: 10px;
            }
            .main-content h1 {
                font-size: 2rem;
            }
        }
    </style>
</head>
<body>

    <video id="video-bg" autoplay muted loop playsinline>
        <source src="bg-video.mp4" type="video/mp4">
    </video>

    <header>
        <nav>
            <ul>
                <li><a href="#">WORK</a></li>
                <li><a href="#">PROFILE</a></li>
                <li><a href="#">NEWS</a></li>
                <li><a href="#">FAQ</a></li>
                <li><a href="#">CONTACT</a></li>
            </ul>
        </nav>
    </header>

    <div class="main-content">
        <h1>PORTFOLIO</h1>
    </div>

</body>
</html>
